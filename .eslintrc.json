{
  "extends": ["react-app"],
  "rules": {
    "no-undef": "off",
    "no-unused-vars": "off"
  },
  "overrides": [
    {
      "files": ["src/**/*.js", "src/**/*.jsx", "**/src/**/*.js", "**/src/**/*.jsx"],
