{
  "name": "rksinfra-nextjs",
  "version": "2.0.1",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/pre-build-fix.js",
    "build": "node scripts/pre-build-fix.js && next build",
    "build:react": "node scripts/pre-build-fix.js && react-scripts build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "cleanup": "node scripts/cleanup-old-files.js",
    "fix-old-files": "node scripts/pre-build-fix.js"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.294.0",
